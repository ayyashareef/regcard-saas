DATABASE_URL="postgresql://user:password@localhost:5432/regcard"
NEXTAUTH_SECRET="change-this-to-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"
UPLOAD_DIR="./uploads"
CRON_SECRET="change-this-to-a-random-cron-secret"

# Seed credentials — REQUIRED when running `prisma db seed` with NODE_ENV=production.
# In dev they're optional; if unset, seed generates random passwords and prints them once.
# Each must be at least 12 characters.
# SEED_SUPER_ADMIN_EMAIL="superadmin@regcard.local"
# SEED_SUPER_ADMIN_PASSWORD=
# SEED_MANAGER_EMAIL="manager@regcard.local"
# SEED_MANAGER_PASSWORD=
# SEED_STAFF_EMAIL="staff@regcard.local"
# SEED_STAFF_PASSWORD=
